{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ES2022",
    "lib": ["ES2017", "DOM", "WebWorker", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "@builder.io/qwik",
    "strict": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true,
    "outDir": "tmp/tsc-out",
    "tsBuildInfoFile": "tmp/tsc-out/.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
